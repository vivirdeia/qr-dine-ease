# Variables de entorno de CARTA
#
# Copia este archivo a `.env` y rellena los valores solo si vas a conectar
# tu propio proyecto Supabase. Si prefieres seguir en modo demo con
# localStorage no hace falta configurar nada.
#
# Ambas variables son claves publicables (safe para el cliente).
# Nunca uses la clave `service_role` aquí ni la subas al repositorio.

# URL del proyecto Supabase. La encuentras en Supabase Dashboard >
# Project Settings > API > Project URL.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Clave publicable (anon key). La encuentras en Supabase Dashboard >
# Project Settings > API > Project API keys > `anon` `public`.
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"
